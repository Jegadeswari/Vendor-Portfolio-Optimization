{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01VZnan2Q3VZLUvWMry9EhLC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01U5XADnaegb4pD7kPrB6Ka4","name":"Write","input":{"file_path":"C:/Users/rjega/vendor-spend-analysis/step08_score.py","content":"import openpyxl\nimport csv\nimport os\n\n# ── paths ──────────────────────────────────────────────────────────────────\nXLSX = r\"C:/Users/rjega/vendor-spend-analysis/outputs/A - TEMPLATE - RWA - Vendor Spend Strategy (R Jegadeswari).xlsx\"\nOUT  = r\"C:/Users/rjega/vendor-spend-analysis/outputs/step08_strategic_scores.csv\"\n\n# ── hard-coded score overrides ─────────────────────────────────────────────\nSCORE5 = {\n    \"salesforce uk ltd\",\n    \"amazon web services llc\",\n}\n\nSCORE4 = {\n    \"bdo llp\",\n    \"tog uk properties limited\",\n    \"cloudcrossing bvba\",\n    \"navan (tripactions inc)\",\n    \"aetna life and casualty ltd\",\n    \"zagrebtower d.o.o.\",\n    \"big frontier pty ltd (cult of monday)\",\n    \"bisley law ltd\",\n    \"cloud technology solutions ltd\",\n    \"wework singapore pte. ltd.\",\n    \"tmforum\",\n    \"hr solution international gmbh\",\n    \"jensten insurance brokers\",\n    \"telefonica global services gmbh\",\n    \"rsm uk corporate finance llp\",\n    \"infosys\",\n    \"harmonic group limited\",\n    \"4i advisory services\",\n}\n\nSCORE_LABELS = {5: \"Mission Critical\", 4: \"Strategic\", 3: \"Important\",\n                2: \"Marginal\", 1: \"Redundant\"}\n\ndef normalise(name):\n    return str(name).strip().lower() if name else \"\"\n\ndef assign_score(vendor_norm, spend_cat, suggestion, spend):\n    if vendor_norm in SCORE5:\n        return 5\n    if vendor_norm in SCORE4:\n        return 4\n\n    cat  = str(spend_cat).strip() if spend_cat else \"\"\n    sugg = str(suggestion).strip() if suggestion else \"\"\n\n    if cat == \"High Spend\" and sugg == \"Optimize\":\n        return 4\n\n    if cat == \"Medium Spend\":\n        return 3\n\n    if cat == \"Low Spend\":\n        spend_val = spend if spend else 0\n        if sugg == \"Consolidate\" and spend_val > 25000:\n            return 3\n        if (sugg == \"Consolidate\" or sugg == \"Terminate\") and 5000 <= spend_val <= 25000:\n            return 2\n\n    return 1\n\ndef switching_cost(score):\n    if score >= 4: return \"HIGH\"\n    if score == 3: return \"MEDIUM\"\n    return \"LOW\"\n\ndef impl_effort(score):\n    if score >= 4: return \"HIGH\"\n    if score == 3: return \"MEDIUM\"\n    return \"LOW\"\n\ndef time_to_savings(suggestion):\n    s = str(suggestion).strip() if suggestion else \"\"\n    if s == \"Terminate\":  return \"IMMEDIATE\"\n    if s == \"Consolidate\": return \"MEDIUM\"\n    if s == \"Optimize\":   return \"LONG\"\n    return \"MEDIUM\"\n\ndef score_aligned_rec(score):\n    if score >= 4: return \"Optimize\"\n    if score >= 2: return \"Consolidate\"\n    return \"Terminate\"\n\ndef is_conflict(current_sugg, aligned_rec, score):\n    c = str(current_sugg).strip() if current_sugg else \"\"\n    if score >= 4 and c == \"Terminate\":\n        return \"Y\"\n    if c != aligned_rec:\n        return \"Y\"\n    return \"N\"\n\n# ── read workbook ──────────────────────────────────────────────────────────\nwb = openpyxl.load_workbook(XLSX, data_only=True)\nws = wb[\"Vendor Analysis Assessment\"]\n\nrows = list(ws.iter_rows(values_only=True))\n# find header row index\nheader_idx = None\nfor i, row in enumerate(rows):\n    if row[0] and str(row[0]).strip().lower() == \"vendor name\":\n        header_idx = i\n        break\n\nif header_idx is None:\n    raise ValueError(\"Could not find 'Vendor Name' header row\")\n\ndata_rows = rows[header_idx + 1:]\n\nresults = []\nfor row in data_rows:\n    vendor   = row[0]\n    dept     = row[1]\n    spend    = row[2]\n    desc     = row[3]\n    sugg     = row[4]\n    spend_cat= row[5]\n\n    if not vendor or str(vendor).strip() == \"\":\n        continue\n\n    v_norm = normalise(vendor)\n    spend_val = float(spend) if spend is not None else 0.0\n\n    score   = assign_score(v_norm, spend_cat, sugg, spend_val)\n    label   = SCORE_LABELS[score]\n    aligned = score_aligned_rec(score)\n    conflict= is_conflict(sugg, aligned, score)\n\n    results.append({\n        \"Vendor Name\": str(vendor).strip(),\n        \"Department\": str(dept).strip() if dept else \"\",\n        \"Spend (USD)\": spend_val,\n        \"Score\": score,\n        \"Score Label\": label,\n        \"Current Recommendation\": str(sugg).strip() if sugg else \"\",\n        \"Score-Aligned Recommendation\": aligned,\n        \"Switching Cost\": switching_cost(score),\n        \"Implementation Effort\": impl_effort(score),\n        \"Time to Realise Savings\": time_to_savings(sugg),\n        \"Conflict\": conflict,\n    })\n\nprint(f\"Total vendor rows processed: {len(results)}\")\n\n# ── write CSV ──────────────────────────────────────────────────────────────\nfieldnames = [\n    \"Vendor Name\", \"Department\", \"Spend (USD)\", \"Score\", \"Score Label\",\n    \"Current Recommendation\", \"Score-Aligned Recommendation\",\n    \"Switching Cost\", \"Implementation Effort\", \"Time to Realise Savings\",\n    \"Conflict\"\n]\n\nos.makedirs(os.path.dirname(OUT), exist_ok=True)\nwith open(OUT, \"w\", newline=\"\", encoding=\"utf-8\") as f:\n    writer = csv.DictWriter(f, fieldnames=fieldnames)\n    writer.writeheader()\n    writer.writerows(results)\n\nprint(f\"CSV written → {OUT}\")\n\n# ── summary statistics ─────────────────────────────────────────────────────\nfrom collections import Counter\n\nscore_dist = Counter(r[\"Score\"] for r in results)\nconflict_rows = [r for r in results if r[\"Conflict\"] == \"Y\"]\n\nprint(\"\\n=== SCORE DISTRIBUTION ===\")\nfor s in [5, 4, 3, 2, 1]:\n    print(f\"  Score {s} ({SCORE_LABELS[s]}): {score_dist.get(s, 0)}\")\n\nprint(f\"\\n=== TOTAL CONFLICTS: {len(conflict_rows)} ===\")\n\nprint(\"\\n=== CONFLICT TABLE ===\")\nhdr = f\"{'Vendor Name':<50} {'Score':>5}  {'Current Rec':<15} {'Aligned Rec':<15} {'Spend (USD)':>12}\"\nprint(hdr)\nprint(\"-\" * len(hdr))\nfor r in sorted(conflict_rows, key=lambda x: -x[\"Spend (USD)\"]):\n    print(f\"{r['Vendor Name']:<50} {r['Score']:>5}  {r['Current Recommendation']:<15} {r['Score-Aligned Recommendation']:<15} {r['Spend (USD)']:>12,.0f}\")\n\n# top 30 by spend\ntop30 = sorted(results, key=lambda x: -x[\"Spend (USD)\"])[:30]\nprint(\"\\n=== TOP 30 ROWS BY SPEND ===\")\nhdr2 = f\"{'Vendor Name':<50} {'Score':>5}  {'Label':<16} {'Current Rec':<15} {'Aligned Rec':<15} {'Conflict':>8} {'Spend (USD)':>12}\"\nprint(hdr2)\nprint(\"-\" * len(hdr2))\nfor r in top30:\n    print(f\"{r['Vendor Name']:<50} {r['Score']:>5}  {r['Score Label']:<16} {r['Current Recommendation']:<15} {r['Score-Aligned Recommendation']:<15} {r['Conflict']:>8} {r['Spend (USD)']:>12,.0f}\")\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":183,"cache_read_input_tokens":9158,"cache_creation":{"ephemeral_5m_input_tokens":183,"ephemeral_1h_input_tokens":0},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01Psa6SrGdQyexzAx1hXbkTy","session_id":"68eb130e-7e1a-4221-ba82-2525f36169e6","uuid":"3a1a2b63-06d5-4556-878f-a01d278be01f"}
